  "description": "Specialty clinical modules for Dental, Dermatology, and Ophthalmology — NPHIES-compliant vertical EMR add-ons for KSA healthcare facilities",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
