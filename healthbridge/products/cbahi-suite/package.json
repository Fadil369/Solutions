{
  "name": "@healthbridge/cbahi-suite",
  "version": "1.0.0",
  "description": "CBAHI Remediation Suite — Accreditation recovery system for hospitals with Denial or Conditional CBAHI status",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit --detectOpenHandles",
    "migrate": "ts-node src/database/migrate.ts",
    "seed": "ts-node src/database/seed.ts"
  },
  "keywords": ["cbahi", "healthcare", "accreditation", "saudi", "hospital"],
  "author": "HealthBridge",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "axios": "^1.13.5",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^8.0.0",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "socket.io": "^4.8.0",
    "uuid": "^14.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/__tests__/**/*.test.ts"]
  }
}
